{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "data:image/svg+xml;base64,",
              "width": "24px",
              "height": "24px"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "${title}",
              "size": "Medium",
              "weight": "Bolder",
              "wrap": true
            }
          ],
          "verticalContentAlignment": "Center"
        }
      ]
    },
    {
      "type": "Image",
      "url": "${staticMapUrl}",
      "size": "Stretch",
      "altText": "Map view: ${title}",
      "spacing": "Small"
    },
    {
      "type": "TextBlock",
      "text": "${description}",
      "wrap": true,
      "spacing": "Small",
      "size": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "View Interactive Map",
      "url": "${interactiveMapUrl}",
      "style": "positive"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Open in Browser",
      "url": "${interactiveMapUrl}"
    }
  ]
}
