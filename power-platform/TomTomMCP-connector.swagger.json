{
  "swagger": "2.0",
  "info": {
    "title": "TomTom MCP Server",
    "description": "TomTom geospatial services via MCP (Model Context Protocol) powered by Orbis Maps. Provides geocoding, routing, traffic, search, EV routing, interactive map generation, and data visualization capabilities deployed on Azure Container Apps.",
    "version": "2.0.0",
    "contact": {
      "name": "TomTom MCP POC",
      "url": "https://github.com/ITSpecialist111/CopilotStudio_TomTom_Map_MCP_POC"
    }
  },
  "host": "<YOUR_CONTAINER_APP>.azurecontainerapps.io",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "api_key": {
      "type": "apiKey",
      "in": "header",
      "name": "tomtom-api-key",
      "description": "TomTom API Key for authentication"
    }
  },
  "security": [
    {
      "api_key": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "GetHealth",
        "summary": "Health Check",
        "description": "Check if the TomTom MCP server is running and healthy",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "string", "description": "Server status (ok)" },
                "backend": { "type": "string", "description": "Backend type" },
                "mode": { "type": "string", "description": "Server mode (http)" },
                "version": { "type": "string", "description": "Server version" }
              }
            }
          }
        }
      }
    },
    "/mcp": {
      "post": {
        "operationId": "CallMcpTool",
        "summary": "Call MCP Tool",
        "description": "Invoke any TomTom MCP tool via JSON-RPC. Supports geocoding, routing, EV routing, search, traffic, interactive maps, and data visualization via Orbis Maps.",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "type": "string",
            "default": "application/json,text/event-stream",
            "description": "Must accept both application/json and text/event-stream",
            "x-ms-visibility": "internal"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["method", "params", "jsonrpc", "id"],
              "properties": {
                "method": {
                  "type": "string",
                  "description": "MCP method to call. Use 'tools/call' to invoke a tool, or 'tools/list' to list available tools.",
                  "enum": ["tools/call", "tools/list"],
                  "default": "tools/call",
                  "x-ms-visibility": "internal"
                },
                "params": {
                  "type": "object",
                  "description": "Parameters for the MCP call. For tools/call, include 'name' and 'arguments'.",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Tool name to invoke",
                      "enum": [
                        "tomtom-geocode",
                        "tomtom-reverse-geocode",
                        "tomtom-fuzzy-search",
                        "tomtom-poi-search",
                        "tomtom-nearby",
                        "tomtom-routing",
                        "tomtom-waypoint-routing",
                        "tomtom-reachable-range",
                        "tomtom-traffic",
                        "tomtom-dynamic-map",
                        "tomtom-ev-routing",
                        "tomtom-search-along-route",
                        "tomtom-area-search",
                        "tomtom-ev-search",
                        "tomtom-data-viz",
                        "tomtom-waypoint-optimization"
                      ]
                    },
                    "arguments": {
                      "type": "object",
                      "description": "Tool-specific arguments"
                    }
                  }
                },
                "jsonrpc": {
                  "type": "string",
                  "description": "JSON-RPC version, always 2.0",
                  "default": "2.0",
                  "x-ms-visibility": "internal"
                },
                "id": {
                  "type": "integer",
                  "description": "Request identifier",
                  "default": 1,
                  "x-ms-visibility": "internal"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful MCP response",
            "schema": {
              "type": "string",
              "description": "Server-Sent Events response containing JSON-RPC result"
            }
          }
        }
      }
    },
    "/api/generate-map-card": {
      "post": {
        "operationId": "GenerateMapCard",
        "summary": "Generate Interactive Map Card",
        "description": "Generate an Adaptive Card with map visualization for Teams. Calls the specified TomTom MCP tool and returns the result wrapped in an Adaptive Card JSON structure suitable for display in Microsoft Teams.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["tool", "arguments"],
              "properties": {
                "tool": {
                  "type": "string",
                  "description": "The TomTom MCP tool to invoke for map generation",
                  "enum": [
                    "tomtom-geocode",
                    "tomtom-reverse-geocode",
                    "tomtom-fuzzy-search",
                    "tomtom-poi-search",
                    "tomtom-nearby",
                    "tomtom-routing",
                    "tomtom-waypoint-routing",
                    "tomtom-reachable-range",
                    "tomtom-traffic",
                    "tomtom-dynamic-map",
                    "tomtom-ev-routing",
                    "tomtom-search-along-route",
                    "tomtom-area-search",
                    "tomtom-ev-search",
                    "tomtom-data-viz",
                    "tomtom-waypoint-optimization"
                  ]
                },
                "arguments": {
                  "type": "object",
                  "description": "Tool-specific arguments to pass to the MCP tool"
                },
                "title": {
                  "type": "string",
                  "description": "Optional title for the Adaptive Card header"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Adaptive Card JSON for Teams display",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Adaptive Card type identifier"
                },
                "version": {
                  "type": "string",
                  "description": "Adaptive Card schema version"
                },
                "body": {
                  "type": "array",
                  "description": "Adaptive Card body elements including map visualization",
                  "items": {
                    "type": "object"
                  }
                },
                "actions": {
                  "type": "array",
                  "description": "Adaptive Card action buttons",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters"
          },
          "500": {
            "description": "Server error during map generation"
          }
        }
      }
    }
  },
  "definitions": {},
  "x-ms-connector-metadata": [
    {
      "propertyName": "Website",
      "propertyValue": "https://developer.tomtom.com/"
    },
    {
      "propertyName": "Privacy policy",
      "propertyValue": "https://www.tomtom.com/privacy/"
    },
    {
      "propertyName": "Categories",
      "propertyValue": "Data;AI"
    }
  ]
}
